&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#8be9fd"&gt;int&lt;/span&gt; i&lt;span style="color:#ff79c6"&gt;=&lt;/span&gt;Integer.&lt;span style="color:#50fa7b"&gt;MAX_VALUE&lt;/span&gt;,j&lt;span style="color:#ff79c6"&gt;=&lt;/span&gt;Integer.&lt;span style="color:#50fa7b"&gt;MAX_VALUE&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;for&lt;/span&gt;(&lt;span style="color:#8be9fd"&gt;int&lt;/span&gt; m&lt;span style="color:#ff79c6"&gt;=&lt;/span&gt;0; m&lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt;nums.&lt;span style="color:#50fa7b"&gt;length&lt;/span&gt;; m&lt;span style="color:#ff79c6"&gt;++&lt;/span&gt;){
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;if&lt;/span&gt;(nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt; &lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt; i){
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; i &lt;span style="color:#ff79c6"&gt;=&lt;/span&gt; nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;if&lt;/span&gt;(i &lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt; nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt; &lt;span style="color:#ff79c6"&gt;&amp;amp;&amp;amp;&lt;/span&gt; nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt; &lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt; j){
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; j &lt;span style="color:#ff79c6"&gt;=&lt;/span&gt; nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;if&lt;/span&gt;(i&lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt; j &lt;span style="color:#ff79c6"&gt;&amp;amp;&amp;amp;&lt;/span&gt; j &lt;span style="color:#ff79c6"&gt;&amp;lt;&lt;/span&gt; nums&lt;span style="color:#ff79c6"&gt;[&lt;/span&gt;m&lt;span style="color:#ff79c6"&gt;]&lt;/span&gt;){
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;return&lt;/span&gt; &lt;span style="color:#ff79c6"&gt;true&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#ff79c6"&gt;return&lt;/span&gt; &lt;span style="color:#ff79c6"&gt;false&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; }
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;
